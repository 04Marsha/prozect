{
  "manifest_version": 3,
  "name": "YSummarize",
  "description": "An extension to provide summarized transcript of a YouTube Subtitle eligible Video.",
  "version": "1.0",

  "action": {
    "default_popup": "popup.html"
  },

  "permissions": ["activeTab", "scripting", "http://127.0.0.1:5000/", "https://ysummariser.onrender.com/"],
  "host_permissions": [
    "https://www.youtube.com/*",
    "http://127.0.0.1:5000/*",
    "https://ysummariser.onrender.com/*"
  ]
}
